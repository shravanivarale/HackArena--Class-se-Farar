# VitalScore Finance Environment Configuration
# Copy this file to .env and update with your actual values

# ============================================
# DATABASE CONFIGURATION
# ============================================

# PostgreSQL (Task 1.2)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vitalscore
DB_USER=postgres
DB_PASSWORD=vitalscore_dev_password
DB_POOL_MIN=2
DB_POOL_MAX=10

# Redis (Task 1.3)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=vitalscore_redis_password
REDIS_DB=0

# InfluxDB (Task 1.4)
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=vitalscore_dev_token
INFLUXDB_ORG=vitalscore
INFLUXDB_BUCKET=vitalscore

# ============================================
# AWS CONFIGURATION (Task 1.1)
# ============================================

AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key

# SQS (Task 1.7)
SQS_QUEUE_URL=http://localhost:4566/000000000000/vitalscore-transactions
SQS_ENDPOINT=http://localhost:4566

# S3 (Task 1.8)
S3_BUCKET_NAME=vitalscore-backups
S3_ENDPOINT=http://localhost:4566

# ============================================
# API GATEWAY (Task 1.5)
# ============================================

API_GATEWAY_PORT=3000
API_GATEWAY_HOST=0.0.0.0
API_BASE_URL=http://localhost:3000/v1

# ============================================
# AUTHENTICATION (Task 4.1-4.3)
# ============================================

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_change_in_production
JWT_EXPIRY=24h
JWT_REFRESH_EXPIRY=30d

# Web3Auth
WEB3AUTH_CLIENT_ID=your_web3auth_client_id
WEB3AUTH_VERIFIER=your_web3auth_verifier

# ============================================
# EXTERNAL INTEGRATIONS
# ============================================

# Razorpay Payment Gateway
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# Aadhaar e-KYC (Task 12.1)
KYC_PROVIDER_URL=https://api.kyc-provider.com
KYC_API_KEY=your_kyc_api_key

# AML RegTech API (Task 12.4)
AML_API_URL=https://api.aml-provider.com
AML_API_KEY=your_aml_api_key

# CPI Data API (Task 7.8.2)
CPI_DATA_API_URL=https://api.data.gov.in
CPI_DATA_API_KEY=your_cpi_api_key

# Push Notifications (Task 11.4)
FCM_SERVER_KEY=your_firebase_server_key
FCM_PROJECT_ID=your_firebase_project_id

# ============================================
# ALGORAND BLOCKCHAIN (Task 9.2)
# ============================================

ALGORAND_NODE_URL=https://testnet-api.algonode.cloud
ALGORAND_INDEXER_URL=https://testnet-idx.algonode.cloud
ALGORAND_NETWORK=testnet
ALGORAND_SYSTEM_WALLET_MNEMONIC=your_25_word_mnemonic_phrase

# IPFS (Task 9.3)
IPFS_API_URL=https://ipfs.infura.io:5001
IPFS_PROJECT_ID=your_ipfs_project_id
IPFS_PROJECT_SECRET=your_ipfs_project_secret

# ============================================
# ML/AI CONFIGURATION
# ============================================

# Groq API (5-Layer Accuracy Engine — Layer 3 LLM)
# Free tier: 6,000 RPM with llama-3.1-70b-versatile
# Sign up: https://console.groq.com
GROQ_API_KEY=your_groq_api_key

# Legacy SageMaker (optional — replaced by Groq in v4)
SAGEMAKER_ENDPOINT=your_sagemaker_endpoint
ML_MODEL_BUCKET=vitalscore-ml-models
ML_MODEL_VERSION=v1.0

# ============================================
# SUPABASE (v4 Free Tier Database)
# ============================================

# Sign up: https://supabase.com — free tier includes 500MB DB + Auth
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_key

# ============================================
# WHATSAPP CLOUD API (SplitSync FM-01)
# ============================================

# Meta Cloud API: https://developers.facebook.com/docs/whatsapp/cloud-api
# Free tier: 1,000 messages/month
WHATSAPP_TOKEN=your_whatsapp_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id

# ============================================
# INVESTMENTS (MicroSave FM-03)
# ============================================

GROWW_API_KEY=your_groww_sandbox_key
GROWW_ENV=sandbox

# ============================================
# MONITORING (Task 19.2-19.3)
# ============================================

DATADOG_API_KEY=your_datadog_api_key
DATADOG_APP_KEY=your_datadog_app_key

PAGERDUTY_INTEGRATION_KEY=your_pagerduty_key

# ============================================
# APPLICATION SETTINGS
# ============================================

NODE_ENV=development
LOG_LEVEL=debug
PORT=3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGIN=http://localhost:3001,http://localhost:19006,http://localhost:5173

# ============================================
# FEATURE FLAGS
# ============================================

ENABLE_ESCROW=true
ENABLE_SQUADS=true
ENABLE_ML_CATEGORIZATION=true
ENABLE_BLOCKCHAIN=true
ENABLE_B2B_DASHBOARD=false
ENABLE_SUBVAMPIRE=true
ENABLE_SPLITSYNC=true
ENABLE_SMART_NUDGE=true
ENABLE_SCORE_INTEGRITY=true
